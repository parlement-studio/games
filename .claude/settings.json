{
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true
  },
  "dangerouslySkipPermissions": true,
  "mcpServers": {
    "blender": {
      "command": "uvx",
      "args": [
        "blender-mcp"
      ]
    },
    "robloxstudio-mcp": {
      "command": "npx",
      "args": ["-y", "robloxstudio-mcp@latest"]
    }
  }
}
